MODE=nnunet                     # "nnunet" (real) or "threshold" (demo, no model)
ALLOW_ORIGINS=*                 # set to your site origin in production
MAX_UPLOAD_MB=500

# nnU-Net paths (absolute recommended in production)
nnUNet_raw=./data/nnUNet_raw
nnUNet_preprocessed=./data/nnUNet_preprocessed
nnUNet_results=./data/nnUNet_results

# nnU-Net prediction settings (defaults match the Fibroid/Uterus model)
NNUNET_DATASET=110              # id or Dataset110_Fibnet_Filtered_nnUnet
NNUNET_CONFIG=3d_fullres
NNUNET_FOLDS=0
NNUNET_TRAINER=nnUNetTrainer
NNUNET_PLANS=nnUNetPlans
NNUNET_CHECKPOINT=checkpoint_best.pth
NNUNET_DEVICE=cpu               # cpu | cuda | mps
NNUNET_DISABLE_TTA=1
